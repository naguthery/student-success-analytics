    {
      "cell_type": "code",
      "source": [
        "duckdb.sql(\"\"\"\n",
        "-- Students who started in Fall 2024\n",
        "WITH Fall2024 AS (\n",
        "  SELECT DISTINCT e.StudentID\n",
        "  FROM Enrollments e\n",
        "  JOIN CourseSections cs ON e.SectionID = cs.SectionID\n",
        "  JOIN Terms t ON cs.TermID = t.TermID\n",
        "  WHERE t.TermName = 'Fall' AND t.AcademicYear = 2024\n",
        "  )\n",
        "\n",
        "SELECT\n",
        "  COUNT(DISTINCT f.StudentID) AS \"Students in Fall 2024\", -- Total Students in Fall 2024\n",
        "  COUNT(DISTINCT e.StudentID) AS \"Students Returning\", -- Students Returning\n",
        "  ROUND(COUNT(DISTINCT e.StudentID) / COUNT(DISTINCT f.StudentID), 2) AS \"Retiontion Rate\" -- Retention Rate = (Students Returning / Students in Original Cohort) * 100\n",
        "FROM Fall2024 f\n",
        "LEFT JOIN Enrollments e ON f.StudentID = e.StudentID\n",
        "\"\"\").df()"
