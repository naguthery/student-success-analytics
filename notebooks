      "source": [
        "#### Instructor Pass Rate = (Studnets Passed / Students Taught) * 100"
      ],
      "metadata": {
        "id": "lLeHjK1Cb3oW"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "duckdb.sql(\"\"\"\n",
        "SELECT\n",
        "  CONCAT(i.FirstName, ' ', i.LastName) AS \"Instructor Name\", -- Instructor's Name\n",
        "  ROUND(SUM(CASE WHEN g.PassFail = 'Pass' THEN 1 ELSE 0 END) / COUNT(*) * 100.0, 2) AS \"Instructor Pass Rate\" -- Instructor Pass Rate = (Studnets Passed / Students Taught) * 100\n",
        "FROM Instructors i\n",
        "JOIN Departments d ON i.DepartmentID = d.DepartmentID\n",
        "JOIN Courses c ON d.DepartmentID = c.DepartmentID\n",
        "JOIN CourseSections cs ON c.CourseID = cs.CourseID\n",
        "JOIN Enrollments e ON cs.SectionID = e.SectionID\n",
        "JOIN Grades g ON e.EnrollmentID = g.EnrollmentID\n",
        "GROUP BY i.FirstName, i.LastName\n",
        "ORDER BY \"Instructor Pass Rate\" DESC;\n",
        "  \"\"\").df()"
      ],
