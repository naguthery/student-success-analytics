      "cell_type": "code",
      "source": [
        "duckdb.sql(\"\"\"\n",
        "SELECT\n",
        "  p.ProgramName, -- Program Name\n",
        "  COUNT(*) AS \"Total Enrollments\", -- Total of studnet enrolled into programs\n",
        "  SUM(CASE WHEN g.PassFail = 'Pass' THEN 1 ELSE 0 END) AS \"Program Passes\", -- Total of students who passed programs\n",
        "  ROUND(SUM(CASE WHEN g.PassFail = 'Pass' THEN 1 ELSE 0 END) / COUNT(*) * 100.0, 2) AS \"Program Pass Rate\" -- Program Pass Rate = (Program Passes / Program Enrollments) * 100\n",
        "FROM Programs p\n",
        "JOIN Students s on p.ProgramID = s.ProgramID\n",
        "JOIN Enrollments e on s.StudentID = e.StudentID\n",
        "JOIN Grades g on e.EnrollmentID = g.EnrollmentID\n",
        "GROUP BY p.ProgramName\n",
        "ORDER BY \"Program Pass Rate\" DESC;\n",
        "\"\"\").df()"
