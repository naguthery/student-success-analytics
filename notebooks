        "#### High-Risk Rate = (High-Risk Students / Total Students) * 100"
      ],
      "metadata": {
        "id": "8hZbNRT81KQl"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "duckdb.sql(\"\"\"\n",
        "SELECT\n",
        "    COUNT(DISTINCT CASE\n",
        "        WHEN g.FinalGrade < 50\n",
        "        THEN e.StudentID\n",
        "    END) AS \"At-Risk Students\",\n",
        "\n",
        "    COUNT(DISTINCT e.StudentID) AS \"Total Students\",\n",
        "\n",
        "    ROUND(\n",
        "        100.0 *\n",
        "        COUNT(DISTINCT CASE\n",
        "            WHEN g.FinalGrade < 50\n",
        "            THEN e.StudentID\n",
        "        END)\n",
        "        / NULLIF(COUNT(DISTINCT e.StudentID), 0),\n",
        "        2\n",
        "    ) AS \"At-Risk Rate\"\n",
        "FROM Enrollments e\n",
        "JOIN Grades g\n",
        "    ON e.EnrollmentID = g.EnrollmentID\n",
        "\"\"\").df()"
