  <worksheets>
    <worksheet name='Courses'>
      <layout-options>
        <title>
          <formatted-text>
            <run>Top 10 Courses by Pass Rate</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Instructors.csv+ (Multiple Connections)' name='federated.1ihncgg0b9j38e16tvukj1n6txpt' />
          </datasources>
          <datasource-dependencies datasource='federated.1ihncgg0b9j38e16tvukj1n6txpt'>
            <column caption='Academic Year' datatype='integer' name='[AcademicYear]' role='dimension' type='quantitative' />
            <column caption='Pass Rate' datatype='real' default-format='p0.00%' name='[Calculation_1456044729925635]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(&#13;&#10;    IF [PassFail] = &quot;Pass&quot; THEN 1 ELSE 0 END&#13;&#10;)&#13;&#10;/&#13;&#10;COUNT([StudentID])' />
            </column>
            <column caption='Course Name' datatype='string' name='[CourseName]' role='dimension' type='nominal' />
            <column caption='Pass Fail' datatype='string' name='[PassFail]' role='dimension' type='nominal' />
            <column caption='Student ID' datatype='integer' name='[StudentID]' role='dimension' type='ordinal' />
            <column caption='Term Name' datatype='string' name='[TermName]' role='dimension' type='nominal' />
            <column-instance column='[AcademicYear]' derivation='None' name='[none:AcademicYear:qk]' pivot='key' type='quantitative' />
            <column-instance column='[CourseName]' derivation='None' name='[none:CourseName:nk]' pivot='key' type='nominal' />
